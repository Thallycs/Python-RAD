# -- coding: utf-8 --
import json
import os
import hashlib
import getpass

USERS_FILE = 'usuarios.json'
TASKS_FILE = 'tarefas.json'


def load_json(path, default):
    if os.path.exists(path):
        with open(path, 'r', encoding='utf-8') as f:
            try:
                return json.load(f)
            except json.JSONDecodeError:
                return default
    return default


def save_json(path, data):
    with open(path, 'w', encoding='utf-8') as f:
        json.dump(data, f, ensure_ascii=False, indent=4)


def hash_password(pw):
    return hashlib.sha256(pw.encode('utf-8')).hexdigest()


def find_user(users, username):
    for u in users:
        if u.get('username') == username:
            return u
    return None


def register_user(users):
    print("Registro de usuário")
    username = input("Escolha um usuário: ").strip()
    if not username:
        print("Nome de usuário não pode ser vazio.")
        return None
    if find_user(users, username):
        print("Usuário já existe.")
        return None
    full_name = input("Nome completo: ").strip()
    while True:
        pw = getpass.getpass("Senha: ")
        pw2 = getpass.getpass("Confirme a senha: ")
        if pw != pw2:
            print("Senhas não coincidem. Tente novamente.")
        elif len(pw) < 4:
            print("A senha deve ter pelo menos 4 caracteres.")
        else:
            break
    users.append({'username': username, 'password_hash': hash_password(pw), 'full_name': full_name})
    save_json(USERS_FILE, users)
    print("Usuário registrado com sucesso.")
    return username


def login_user(users):
    print("Login")
    username = input("Usuário: ").strip()
    pw = getpass.getpass("Senha: ")
    user = find_user(users, username)
    if not user:
        print("Usuário não encontrado.")
        return None
    if user['password_hash'] != hash_password(pw):
        print("Senha incorreta.")
        return None
    print(f"Bem-vindo, {user.get('full_name', username)}!")
    return username


def load_data():
    users = load_json(USERS_FILE, [])
    tasks = load_json(TASKS_FILE, [])
    return users, tasks


def save_tasks(tasks):
    save_json(TASKS_FILE, tasks)


def list_tasks(tasks, owner):
    owner_tasks = [t for t in tasks if t.get('owner') == owner]
    if not owner_tasks:
        print("Nenhuma tarefa encontrada.")
        return
    for t in sorted(owner_tasks, key=lambda x: x['id']):
        status = "Concluída" if t.get('done') else "Pendente"
        print(f"[{t['id']}] {t['title']} - {status}")
        if t.get('description'):
            print(f"    Descrição: {t['description']}")


def create_task(tasks, owner):
    title = input("Título da tarefa: ").strip()
    if not title:
        print("Título não pode ser vazio.")
        return
    description = input("Descrição (opcional): ").strip()
    existing_ids = [t['id'] for t in tasks] if tasks else []
    new_id = max(existing_ids) + 1 if existing_ids else 1
    tasks.append({'id': new_id, 'owner': owner, 'title': title, 'description': description, 'done': False})
    save_tasks(tasks)
    print(f"Tarefa [{new_id}] criada.")


def update_task(tasks, owner):
    try:
        tid = int(input("ID da tarefa a atualizar: ").strip())
    except ValueError:
        print("ID inválido.")
        return
    task = next((t for t in tasks if t['id'] == tid and t['owner'] == owner), None)
    if not task:
        print("Tarefa não encontrada.")
        return
    print(f"Atualizando tarefa [{tid}]: {task['title']}")
    new_title = input("Novo título (deixe vazio para manter): ").strip()
    new_desc = input("Nova descrição (deixe vazio para manter): ").strip()
    new_done = input("Concluída? (s/n, deixe vazio para manter): ").strip().lower()
    if new_title:
        task['title'] = new_title
    if new_desc:
        task['description'] = new_desc
    if new_done in ('s', 'sim', 'y', 'yes'):
        task['done'] = True
    elif new_done in ('n', 'nao', 'não', 'no'):
        task['done'] = False
    save_tasks(tasks)
    print("Tarefa atualizada.")


def delete_task(tasks, owner):
    try:
        tid = int(input("ID da tarefa a excluir: ").strip())
    except ValueError:
        print("ID inválido.")
        return
    idx = next((i for i, t in enumerate(tasks) if t['id'] == tid and t['owner'] == owner), None)
    if idx is None:
        print("Tarefa não encontrada.")
        return
    confirm = input(f"Confirma excluir a tarefa [{tid}]? (s/n): ").strip().lower()
    if confirm in ('s', 'sim', 'yes', 'y'):
        tasks.pop(idx)
        save_tasks(tasks)
        print("Tarefa excluída.")
    else:
        print("Operação cancelada.")


def main_menu():
    print("=== Gerenciador de Tarefas com Login ===")
    print("Requisitos funcionais atendidos:")
    print("- RF1: Autenticação com login e registro de usuários")
    print("- RF2: CRUD de tarefas (Criar, Ler, Atualizar, Excluir)")
    print("- RF3: Persistência de dados em arquivo JSON")
    print("- RF4: Validação básica de entradas e mensagens amigáveis")
    print("")


def main():
    main_menu()
    # load data
    users, tasks = load_data()
    while True:
        print("\nMenu principal:")
        print("1 - Entrar")
        print("2 - Registrar")
        print("3 - Sair")
        op = input("Escolha uma opção: ").strip()
        if op == '1':
            user = login_user(users)
            if not user:
                continue
            # user session
            while True:
                print("\nDashboard")
                print("1 - Criar tarefa")
                print("2 - Listar minhas tarefas")
                print("3 - Atualizar tarefa")
                print("4 - Excluir tarefa")
                print("5 - Desconectar")
                choice = input("Escolha uma opção: ").strip()
                if choice == '1':
                    create_task(tasks, user)
                elif choice == '2':
                    list_tasks(tasks, user)
                elif choice == '3':
                    update_task(tasks, user)
                elif choice == '4':
                    delete_task(tasks, user)
                elif choice == '5':
                    print("Desconectando...")
                    break
                else:
                    print("Opção inválida.")
        elif op == '2':
            reg_user = register_user(users)
            if reg_user:
                # após registro, usuário pode fazer login na sessão de registro
                user = reg_user
                while True:
                    print("\nDashboard")
                    print("1 - Criar tarefa")
                    print("2 - Listar minhas tarefas")
                    print("3 - Atualizar tarefa")
                    print("4 - Excluir tarefa")
                    print("5 - Desconectar")
                    choice = input("Escolha uma opção: ").strip()
                    if choice == '1':
                        create_task(tasks, user)
                    elif choice == '2':
                        list_tasks(tasks, user)
                    elif choice == '3':
                        update_task(tasks, user)
                    elif choice == '4':
                        delete_task(tasks, user)
                    elif choice == '5':
                        print("Desconectando...")
                        break
                    else:
                        print("Opção inválida.")
            else:
                print("Falha no registro.")
        elif op == '3':
            print("Encerrando o programa.")
            break
        else:
            print("Opção inválida. Tente novamente.")


if __name__== '_main_':
    main()
